[sub_resource type="GDScript" id="GDScript_omvil"]
script/source = "extends ColorRect

# --- 1. ПОСИЛАННЯ НА ВУЗЛИ (Node References) ---
@onready var panel = $Panel
@onready var panel_log = $PanelLog
@onready var label_header = $PanelLog/top
@onready var label_status = $Panel/top
@onready var label_level = $Panel/Level/top
@onready var label_log_hint = $Panel/Log

@onready var btn_label1 = $Panel/Button1/top
@onready var btn_label2 = $Panel/Button2/top
@onready var btn_label3 = $Panel/Button3/top
@onready var btn_label4 = $Panel/Button4/top

@onready var label_log_history = $PanelLog/ScrollContainer/VBoxContainer/Log
@onready var label_log = $\"../Text\"      
@onready var label_log_old = $\"../TextOld\" 
@onready var chat_input = $\"../TextEdit\" 

# Бінарні кнопки (Так/Ні)
@onready var btn_yes = $\"../Yes\"
@onready var btn_no = $\"../No\"

# Кнопки вибору (1V-4V)
@onready var btn_1v = $\"../1V\"
@onready var btn_2v = $\"../2V\"
@onready var btn_3v = $\"../3V\"
@onready var btn_4v = $\"../4V\"
var multi_btns = []
var current_options_keys = [] 

# --- НОВЕ: Словник НПС для логів ---
var npc_suffixes = {
	\"Діно\": \".vap\",
	\"Ґіно\": \".vap\",
	\"Вано\": \".var\",
	\"Гроно\": \".var\",
	\"Коно\": \".var\",
	\"Діглюно\": \".var\" # Додавай сюди нових монстрів або НПС
}

# --- 2. СИГНАЛИ ТА ЗМІННІ СТАНУ ---
signal choice_selected(value: bool)
signal multi_choice_selected(index: int) 

var id_header: String; var id_status: String
var id_level: String; var id_log_hint: String
var btn_ids = []

var glitch_symbols = \"&$#%?!*@§ΔΣΩXYZV\"
var anim_id: int = 0 
var log_message_id: int = 0
var active_tween: Tween
var fade_tween: Tween 
var is_in_logs: bool = false 
var is_in_stone: bool = false 
var was_dino_blocked: bool = false 

# НОВЕ: Змінна для збереження чистого тексту
var last_clean_chat_text: String = \"\"

# --- 3. ІНІЦІАЛІЗАЦІЯ (Ready) ---

func _ready():
	if label_header: id_header = label_header.text
	if label_status: id_status = label_status.text
	if label_level: id_level = label_level.text
	if label_log_hint: id_log_hint = label_log_hint.text
	if btn_label1: btn_ids = [btn_label1.text, btn_label2.text, btn_label3.text, btn_label4.text]
	
	if lang.has_signal(\"language_changed\"):
		lang.language_changed.connect(_update_ui_translation)
	
	if is_instance_valid(panel): panel.visible = false
	if is_instance_valid(panel_log): panel_log.visible = false
	
	if is_instance_valid(btn_yes): 
		btn_yes.visible = false
		if not btn_yes.pressed.is_connected(_on_choice_pressed):
			btn_yes.pressed.connect(_on_choice_pressed.bind(true))
			
	if is_instance_valid(btn_no): 
		btn_no.visible = false
		if not btn_no.pressed.is_connected(_on_choice_pressed):
			btn_no.pressed.connect(_on_choice_pressed.bind(false))
			
	multi_btns = [btn_1v, btn_2v, btn_3v, btn_4v]
	for i in range(multi_btns.size()):
		if is_instance_valid(multi_btns[i]):
			multi_btns[i].visible = false
			if not multi_btns[i].pressed.is_connected(_on_multi_choice_pressed):
				multi_btns[i].pressed.connect(_on_multi_choice_pressed.bind(i + 1))
	
	if chat_input: 
		chat_input.visible = false
		if not chat_input.gui_input.is_connected(_on_chat_gui_input):
			chat_input.gui_input.connect(_on_chat_gui_input)
			
	self.visible = false

# --- 4. СИСТЕМА ВИБОРУ ТА ВВОДУ ---

func _on_choice_pressed(value: bool):
	choice_selected.emit(value)
	if is_instance_valid(btn_yes): btn_yes.visible = false
	if is_instance_valid(btn_no): btn_no.visible = false

func _on_multi_choice_pressed(index: int):
	multi_choice_selected.emit(index)
	for btn in multi_btns:
		if is_instance_valid(btn): btn.visible = false
	current_options_keys.clear()

func _unhandled_input(event):
	if not is_instance_valid(chat_input): return 
	
	var is_choosing = false
	if is_instance_valid(btn_yes) and btn_yes.visible: is_choosing = true
	for btn in multi_btns:
		if is_instance_valid(btn) and btn.visible: is_choosing = true

	if self.visible or chat_input.visible or is_choosing: 
		return 
	
	if (event is InputEventKey and event.pressed and event.keycode == KEY_T) or event.is_action_pressed(\"enter\"):
		_open_chat()
		get_viewport().set_input_as_handled()

func _on_chat_gui_input(event):
	if event is InputEventKey and event.pressed:
		if event.keycode == KEY_ENTER or event.keycode == KEY_KP_ENTER:
			get_viewport().set_input_as_handled()
			var msg = chat_input.text.strip_edges()
			_close_chat()
			if msg != \"\" and not _check_for_commands(msg):
				add_new_dialogue(\"Діно\", msg, false)
		elif event.keycode == KEY_ESCAPE:
			get_viewport().set_input_as_handled()
			_close_chat()

# --- НОВЕ: ФУНКЦІЯ ОЧИЩЕННЯ ТЕГІВ ---
# Ця функція вирізає всі [w0.5], [q], [q4] з тексту
func clean_tags(text: String) -> String:
	var result = \"\"
	var i = 0
	while i < text.length():
		if text[i] == \"[\":
			var close_idx = text.find(\"]\", i)
			if close_idx != -1:
				i = close_idx + 1
				continue
		result += text[i]
		i += 1
	return result

# --- 5. ЛОГІКА ДІАЛОГІВ ---

func add_new_dialogue(arg1: String, arg2: String = \"\", translate: bool = true, options: Array = []) -> Variant:
	# --- ВИПРАВЛЕННЯ БАГУ ЗІ СКІПОМ ---
	# Тепер ми переносимо в старий лог ТІЛЬКИ ідеально чистий текст, а не те що встигло надрукуватись
	if last_clean_chat_text != \"\":
		var old_prefix = \"\\n\" if label_log_old.text != \"\" else \"\"
		label_log_old.text += old_prefix + last_clean_chat_text
		
		var lines = label_log_old.text.split(\"\\n\")
		if lines.size() > 4:
			lines = lines.slice(lines.size() - 4, lines.size())
			label_log_old.text = \"\\n\".join(lines)
		
		label_log_old.modulate.a = 1.0 
		last_clean_chat_text = \"\"
	
	var is_sep = (arg1 == \"-\" and arg2 == \"-\")
	var raw_speaker = arg1 if arg2 != \"\" else \"\"
	var raw_text = arg2 if arg2 != \"\" else arg1
	
	# --- ПЕРЕКЛАД ІМЕН ---
	var translated_speaker = lang.text_sign(raw_speaker) if translate and raw_speaker != \"\" else raw_speaker
	var translated_text = lang.text_sign(raw_text) if translate else raw_text
	
	var is_binary_q = translated_text.contains(\"[q]\")
	var multi_q_count = 0
	for i in range(1, 5):
		if translated_text.contains(\"[q%d]\" % i):
			multi_q_count = i
			break
	
	# --- ФОРМУВАННЯ ПРЕФІКСІВ ДЛЯ ЧАТУ ТА ЛОГІВ ---
	var chat_prefix = \"\"
	var log_prefix = \"\"
	
	if not is_sep and raw_speaker != \"\":
		# Витягуємо суфікс із нашого словника (якщо немає - залишаємо порожнім або даємо дефолт)
		var suffix = npc_suffixes.get(raw_speaker, \"\") 
		chat_prefix = \"- \" + translated_speaker + \": \"
		log_prefix = \"- \" + translated_speaker + suffix + \": \"
	
	var cleaned_text = clean_tags(translated_text)
	
	if is_sep:
		last_clean_chat_text = \"------------------------------------\"
	else:
		last_clean_chat_text = chat_prefix + cleaned_text
	
	log_message_id += 1
	var current_msg_id = log_message_id
	var v = anim_id 
	if fade_tween: fade_tween.kill()
	label_log.modulate.a = 1.0
	label_log_old.modulate.a = 1.0 if label_log_old.text != \"\" else 0.0
	
	if is_sep:
		label_log.text = last_clean_chat_text
		label_log_history.text += \"\\n\" + last_clean_chat_text
		_scroll_to_bottom()
		await get_tree().process_frame
	else:
		# Передаємо префікси та чистий текст у функцію анімації
		await animate_dual_log(translated_text, chat_prefix, log_prefix, \"\\n\", v)
	
	if is_binary_q:
		if is_instance_valid(btn_yes): btn_yes.visible = true
		if is_instance_valid(btn_no): btn_no.visible = true
		return await choice_selected 
		
	if multi_q_count > 0:
		current_options_keys = options 
		var actual_count = min(multi_q_count, options.size())
		
		for i in range(actual_count):
			if is_instance_valid(multi_btns[i]):
				var btn_label = multi_btns[i].get_node_or_null(\"top\")
				var translated_opt = lang.text_sign(options[i]) if translate else options[i]
				
				if btn_label: btn_label.text = translated_opt
				else: multi_btns[i].text = translated_opt
				
				multi_btns[i].visible = true
				
		return await multi_choice_selected 
	
	await get_tree().create_timer(4).timeout
	if current_msg_id == log_message_id: clear_hot_log()
	return false

# --- ОНОВЛЕНА ФУНКЦІЯ АНІМАЦІЇ ---
func animate_dual_log(raw_text: String, chat_prefix: String, log_prefix: String, history_prefix: String, v: int):
	# 1. Отримуємо ідеально чистий текст без тегів заздалегідь
	var clean_full_text = clean_tags(raw_text) 
	
	# 2. ОДРАЗУ додаємо його в історію логів (Без жодних анімацій!)
	label_log_history.text += history_prefix + log_prefix + clean_full_text
	_scroll_to_bottom() # Відразу прокручуємо логи вниз
	
	var current_display = \"\"
	var i = 0
	
	# 3. Анімація працює ТІЛЬКИ для активного чату (label_log)
	while i < raw_text.length():
		if v != anim_id: 
			# Якщо був скіп, просто миттєво дописуємо чат і виходимо
			label_log.text = chat_prefix + clean_full_text
			return 
		
		# Обробка тегів [w...] та [q...]
		if raw_text[i] == \"[\":
			var close_idx = raw_text.find(\"]\", i)
			if close_idx != -1:
				var tag = raw_text.substr(i, close_idx - i + 1)
				if tag.begins_with(\"[w\"):
					var wait_str = tag.substr(2, tag.length() - 3)
					if wait_str.is_valid_float():
						await get_tree().create_timer(wait_str.to_float()).timeout
				i = close_idx + 1
				continue
				
		for frame in range(2):
			# Глітч показується ТІЛЬКИ в основному чаті
			label_log.text = chat_prefix + current_display + glitch_symbols[randi() % glitch_symbols.length()]
			await get_tree().create_timer(0.01).timeout
			
			if v != anim_id: 
				# Захист від скіпу під час мікро-затримки
				label_log.text = chat_prefix + clean_full_text
				return 
			
		current_display += raw_text[i]
		label_log.text = chat_prefix + current_display
		i += 1

# --- 6. ДОПОМІЖНІ ФУНКЦІЇ ---

func _scroll_to_bottom():
	var scroll = $PanelLog/ScrollContainer
	if scroll: await get_tree().process_frame; scroll.scroll_vertical = scroll.get_v_scroll_bar().max_value

func _open_chat():
	var dino = $\"../../../Dino\"
	if dino: was_dino_blocked = not dino.controls_dino; dino.controls_dino = false 
	chat_input.visible = true; chat_input.grab_focus(); chat_input.text = \"\"
	if fade_tween: fade_tween.kill()
	label_log.modulate.a = 1.0; if label_log_old.text != \"\": label_log_old.modulate.a = 1.0

func _close_chat():
	var dino = $\"../../../Dino\"
	chat_input.text = \"\"; chat_input.release_focus(); chat_input.visible = false
	if dino and not was_dino_blocked: dino.controls_dino = true

func _check_for_commands(input_text: String) -> bool:
	var raw = input_text.to_lower() # Переводимо все в нижній регістр, щоб не залежало від CapsLock
	var parts = raw.split(\" \")
	
	# 1. Твоя стара команда для емоцій
	if parts[0] == \"-emotion\" or parts[0] == \"-e\":
		if parts.size() > 1: 
			_execute_emotion_command(parts[1].to_int())
		return true 
		
	# --- НОВІ КОМАНДИ ---
	
	# 2. Команда: -music off
	if raw == \"-music off\":
		var music_player = $\"../../../Music\" # ПЕРЕВІР ШЛЯХ ДО СВОГО МУЗИЧНОГО ВУЗЛА!
		if is_instance_valid(music_player):
			music_player.stop_track(1.0) # Плавно вимикаємо за 1 секунду
			
			# Додаємо системне повідомлення в історію логів
			label_log_history.text += \"\\n[SYSTEM]: Music disabled\"
			_scroll_to_bottom()
		return true # Повертаємо true, щоб Діно не сказав це вголос

	# 3. Додатковий приклад: -music play bg1
	if parts[0] == \"-music\" and parts[1] == \"play\" and parts.size() > 2:
		var music_player = $\"../../../Music\"
		if is_instance_valid(music_player):
			var track_name = parts[2] # Беремо назву треку (наприклад, bg1)
			music_player.play_track(track_name, 1.0)
			
			label_log_history.text += \"\\n[SYSTEM]: Playing track '\" + track_name + \"'\"
			_scroll_to_bottom()
		return true

	if raw == \"-help\":
		label_log_history.text += \"\\n[HELP]:\\n-e {number}\\n-music off\\n-music play {bg}\"
		_scroll_to_bottom()
		return true
	
	# Якщо жодна команда не підійшла, повертаємо false (це просто звичайний текст гравця)
	return false

func _execute_emotion_command(id: int):
	var node = $\"../../../Dino/Emotion\"
	if node: node.emotion = id; label_log_history.text += \"\\n[SYSTEM]: Emotion \" + str(id)

func clear_hot_log():
	fade_tween = create_tween().set_parallel(true)
	fade_tween.tween_property(label_log, \"modulate:a\", 0.0, 1.5)
	fade_tween.tween_property(label_log_old, \"modulate:a\", 0.0, 1.5)

func _update_ui_translation():
	if not self.visible: return
	label_header.text = lang.text_sign(id_header); label_status.text = lang.text_sign(id_status)
	label_level.text = lang.text_sign(id_level); label_log_hint.text = lang.text_sign(id_log_hint)
	btn_label1.text = lang.text_sign(btn_ids[0]); btn_label2.text = lang.text_sign(btn_ids[1])
	btn_label3.text = lang.text_sign(btn_ids[2]); btn_label4.text = lang.text_sign(btn_ids[3])
	
	for i in range(multi_btns.size()):
		if is_instance_valid(multi_btns[i]) and multi_btns[i].visible and i < current_options_keys.size():
			var btn_label = multi_btns[i].get_node_or_null(\"top\")
			var translated_opt = lang.text_sign(current_options_keys[i])
			if btn_label: btn_label.text = translated_opt
			else: multi_btns[i].text = translated_opt

func show_title():
	anim_id += 1
	var current_v = anim_id
	is_in_logs = false
	if active_tween: active_tween.kill()
	clear_all_text()
	label_log.visible = false
	label_log_old.visible = false
	if chat_input and chat_input.has_focus(): _close_chat()
	
	panel.visible = true
	panel_log.visible = false
	panel.modulate.a = 0.0
	panel.scale = Vector2(0.8, 0.8)
	self.visible = true
	
	active_tween = create_tween().set_parallel(true)
	active_tween.tween_property(panel, \"modulate:a\", 1.0, 0.2)
	active_tween.tween_property(panel, \"scale\", Vector2(1.0, 1.0), 0.3).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	
	if lang and lang.has_method(\"text_sign\"):
		reveal_minecraft_text(label_header, lang.text_sign(id_header), current_v)
		reveal_minecraft_text(label_level, lang.text_sign(id_level), current_v)
		reveal_minecraft_text(label_status, lang.text_sign(id_status), current_v)
		if btn_ids.size() >= 4:
			reveal_minecraft_text(btn_label1, lang.text_sign(btn_ids[0]), current_v)
			reveal_minecraft_text(btn_label2, lang.text_sign(btn_ids[1]), current_v)
			reveal_minecraft_text(btn_label3, lang.text_sign(btn_ids[2]), current_v)
			reveal_minecraft_text(btn_label4, lang.text_sign(btn_ids[3]), current_v)
		reveal_minecraft_text(label_log_hint, lang.text_sign(id_log_hint), current_v)

func close_console() -> bool:
	if is_in_logs: 
		switch_to_main()
		return false
	anim_id += 1 
	if active_tween: active_tween.kill()
	active_tween = create_tween().set_parallel(true)
	active_tween.tween_property(panel, \"modulate:a\", 0.0, 0.2)
	active_tween.tween_property(panel, \"scale\", Vector2(0.8, 0.8), 0.2).set_trans(Tween.TRANS_QUAD).set_ease(Tween.EASE_IN)
	await active_tween.finished
	self.visible = false
	panel.visible = false 
	label_log.visible = true
	label_log_old.visible = true
	return true

func clear_all_text():
	if label_header: label_header.text = \"\"
	if label_status: label_status.text = \"\"
	if label_level: label_level.text = \"\"
	if label_log_hint: label_log_hint.text = \"\"
	if btn_label1: btn_label1.text = \"\"
	if btn_label2: btn_label2.text = \"\"
	if btn_label3: btn_label3.text = \"\"
	if btn_label4: btn_label4.text = \"\"

func reveal_minecraft_text(label: Label, final_text: String, v: int) -> bool:
	if not label or final_text == \"\": return true
	var current_display = \"\"
	for i in range(final_text.length()):
		if v != anim_id or not self.visible: return false
		for frame in range(2):
			label.text = current_display + glitch_symbols[randi() % glitch_symbols.length()]
			await get_tree().create_timer(0.01).timeout
		current_display += final_text[i]
		label.text = current_display
	return true

func switch_to_logs():
	is_in_logs = true
	if active_tween: active_tween.kill()
	panel_log.visible = true
	active_tween = create_tween().set_parallel(true)
	active_tween.tween_property(panel, \"modulate:a\", 0.0, 0.2)
	active_tween.tween_property(panel, \"scale\", Vector2(0.8, 0.8), 0.2)
	active_tween.chain().set_parallel(true)
	active_tween.tween_property(panel_log, \"modulate:a\", 1.0, 0.2)
	active_tween.tween_property(panel_log, \"scale\", Vector2(1.0, 1.0), 0.3).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	await active_tween.finished
	if is_in_logs: panel.visible = false

func switch_to_stone():
	is_in_logs = true
	if active_tween: active_tween.kill()
	$PanelStone.visible = true
	active_tween = create_tween().set_parallel(true)
	active_tween.tween_property(panel, \"modulate:a\", 0.0, 0.2)
	active_tween.tween_property(panel, \"scale\", Vector2(0.8, 0.8), 0.2)
	active_tween.chain().set_parallel(true)
	active_tween.tween_property($PanelStone, \"modulate:a\", 1.0, 0.2)
	active_tween.tween_property($PanelStone, \"scale\", Vector2(1.0, 1.0), 0.3).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	await active_tween.finished
	if is_in_logs: panel.visible = false

func switch_to_main():
	is_in_logs = false
	if active_tween: active_tween.kill()
	panel.visible = true
	active_tween = create_tween().set_parallel(true)
	active_tween.tween_property(panel_log, \"modulate:a\", 0.0, 0.2)
	active_tween.tween_property($PanelStone, \"modulate:a\", 0.0, 0.2)
	active_tween.tween_property(panel_log, \"scale\", Vector2(0.8, 0.8), 0.2)
	active_tween.tween_property($PanelStone, \"scale\", Vector2(0.8, 0.8), 0.2)
	active_tween.chain().set_parallel(true)
	active_tween.tween_property(panel, \"modulate:a\", 1.0, 0.2)
	active_tween.tween_property(panel, \"scale\", Vector2(1.0, 1.0), 0.3).set_trans(Tween.TRANS_BACK).set_ease(Tween.EASE_OUT)
	await active_tween.finished
	if not is_in_logs: panel_log.visible = false
	if not is_in_logs: $PanelStone.visible = false
"

