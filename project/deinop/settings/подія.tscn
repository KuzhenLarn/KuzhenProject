[sub_resource type="GDScript" id="GDScript_pqsfo"]
script/source = "extends Camera2D

# --- ПАМ'ЯТЬ ---
var default_zoom: Vector2 = Vector2(1.0, 1.0)
var default_speed: float = 5.0
var default_offset: Vector2 = Vector2(0, 0)

func _ready():
	# Зберігаємо початкові налаштування
	default_zoom = self.zoom
	default_speed = self.position_smoothing_speed
	default_offset = self.offset

func change_camera(target_zoom: Vector2, target_speed: float, target_offset: Vector2 = Vector2(0,0), duration: float = 1.2):
	var tween = create_tween().set_parallel(true)
	
	# 1. Плавний зум
	tween.tween_property(self, \"zoom\", target_zoom, duration)\\
		.set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN_OUT)
	
	# 2. Плавна швидкість
	self.position_smoothing_enabled = true
	tween.tween_property(self, \"position_smoothing_speed\", target_speed, duration)\\
		.set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN_OUT)
		
	# 3. Плавне зміщення (Offset)
	tween.tween_property(self, \"offset\", target_offset, duration)\\
		.set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN_OUT)

# --- ФУНКЦІЯ ПОВЕРНЕННЯ ---
func reset_camera(duration: float = 1.2):
	change_camera(default_zoom, default_speed, default_offset, duration)
"

