[sub_resource type="GDScript" id="GDScript_omxjm"]
script/source = "@tool
extends TextureRect

@export_group(\"Frames Logic\")
@export var hframes: int = 1:
	set(val):
		hframes = max(1, val)
		_update_frame()

@export var vframes: int = 1:
	set(val):
		vframes = max(1, val)
		_update_frame()

@export var frame: int = 0:
	set(val):
		frame = val
		_update_frame()

@export_group(\"Animation Settings\")
@export var is_playing: bool = false # Увімкнути/вимкнути анімацію
@export var fps: float = 10.0        # Швидкість кадрів на секунду
@export var loop: bool = true        # Чи зациклювати анімацію

var _accumulator: float = 0.0

func _process(delta: float) -> void:
	if not is_playing or fps <= 0:
		return
		
	_accumulator += delta
	
	# Рахуємо, чи пора перемикати кадр
	var frame_time = 1.0 / fps
	if _accumulator >= frame_time:
		_accumulator = 0.0
		_next_frame()

func _next_frame():
	var max_frames = hframes * vframes
	var next_f = frame + 1
	
	if next_f >= max_frames:
		if loop:
			frame = 0
		else:
			is_playing = false
			frame = max_frames - 1
	else:
		frame = next_f

func _update_frame():
	if texture is AtlasTexture:
		var atlas_tex = texture as AtlasTexture
		if atlas_tex.atlas:
			var atlas_size = atlas_tex.atlas.get_size()
			var frame_w = atlas_size.x / hframes
			var frame_h = atlas_size.y / vframes
			
			var row = frame / hframes
			var col = frame % hframes
			
			atlas_tex.region = Rect2(col * frame_w, row * frame_h, frame_w, frame_h)
"

