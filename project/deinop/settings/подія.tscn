[sub_resource type="GDScript" id="GDScript_xxop1"]
script/source = "extends AudioStreamPlayer

var tracks = {
	\"bg1\": preload(\"res://Аудіо/Музика/Оригінал/BGAlpha1.mp3\"),
	\"bg2\": preload(\"res://Аудіо/Музика/Приглушені/LunaDesert.ogg\"),
	\"bg3\": preload(\"res://Аудіо/Музика/Приглушені/Dereventi.ogg\"),
	\"bg4\": preload(\"res://Аудіо/Музика/Оригінал/Location2.1.mp3\"),
	\"dino_run\": preload(\"res://Аудіо/Музика/Оригінал/dino run.mp3\"),
	\"drey\": preload(\"res://Аудіо/Музика/Оригінал/drey.mp3\")
}

var current_track_name: String = \"\"
var fade_tween: Tween

# --- ГОЛОВНІ ФУНКЦІЇ ---

# Плавно вмикає вибраний трек
# Плавно вмикає вибраний трек
func play_track(track_name: String, fade_time: float = 2.0):
	if current_track_name == track_name: return
	if not tracks.has(track_name): return

	if is_playing():
		await stop_track(fade_time) # Чекаємо, поки стара музика згасне
	
	stream = tracks[track_name]
	current_track_name = track_name
	
	# --- ВИПРАВЛЕННЯ ---
	volume_db = -80.0 # Опускаємо гучність до нуля ПЕРЕД запуском
	
	play()
	_fade(0.0, fade_time) # Плавно до нормальної гучності (0.0)

# Плавно зупиняє будь-яку музику, що зараз грає
func stop_track(fade_time: float = 2.0):
	if not is_playing(): return
	
	current_track_name = \"\" # Очищаємо назву, щоб можна було знову ввімкнути той самий трек
	await _fade(-80.0, fade_time) # Плавно в тишу
	stop() # Повністю зупиняємо плеєр

# --- ВНУТРІШНЯ МАГІЯ (Універсальний фейдер) ---

func _fade(target_db: float, duration: float):
	if fade_tween: fade_tween.kill()
	fade_tween = create_tween()
	
	fade_tween.tween_property(self, \"volume_db\", target_db, duration)\\
		.set_trans(Tween.TRANS_SINE).set_ease(Tween.EASE_IN_OUT)
	
	await fade_tween.finished
"

