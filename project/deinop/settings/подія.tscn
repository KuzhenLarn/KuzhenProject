[sub_resource type="GDScript" id="GDScript_1c1ty"]
script/source = "extends CharacterBody2D

# --- СИГНАЛИ ---
signal game_started

# --- НАЛАШТУВАННЯ ---
@export_group(\"Movement Settings\")
@export var walk_speed: float = 400.0
@export var run_speed: float = 600.0
@export var crawl_speed: float = 200.0
@export var jump_velocity: float = -800.0
@export var gravity: float = 2500.0

@export_group(\"Surface Physics\")
@export var ice_acceleration: float = 2.0
@export var ice_friction: float = 1.0
@export var wind_push_force: float = -60.0 

# --- ПОСИЛАННЯ НА ВНУТРІШНІ ВУЗЛИ ---
@onready var sprite = $AnimatedSprite2D
@onready var col_stand = $CollisionShape2D_Stand
@onready var col_crouch = $CollisionShape2D_Crouch
@onready var ceiling_check = $CeilingCheck

# Внутрішні звуки
@onready var sound_jump = $Jump
@onready var sound_walk = $Walk

# --- СТАН ---
var intro_played = false 
var is_crouching = false
@export var controls_dino = true

# Режими поверхні (внутрішній стан)
enum SurfaceMode { NORMAL, WIND_MILD, WIND_STRONG, ICE }
var current_surface = SurfaceMode.NORMAL

# Мобільний біг
var is_mobile_running: bool = false

func _ready():
	sprite.play(\"norma\")
	col_stand.disabled = false
	col_crouch.disabled = true

func _physics_process(delta):
	# Гравітація
	if not is_on_floor():
		velocity.y += gravity * delta

	# 1. ЛОГІКА ДО СТАРТУ ГРИ
	if not intro_played:
		velocity.x = 0
		if Input.is_action_just_pressed(\"jump\") and is_on_floor() and controls_dino:
			start_game_sequence()
		move_and_slide()
		return

	# 2. ПЕРЕВІРКА ПРИСІДАННЯ
	var trying_to_crouch = Input.is_action_pressed(\"down\")
	var is_ceiling_above = ceiling_check.is_colliding()
	
	if (trying_to_crouch or is_ceiling_above) and controls_dino:
		if not is_crouching: enter_crouch()
	else:
		if is_crouching: exit_crouch()

	# 3. ВИЗНАЧЕННЯ БІГУ
	var is_running = false
	if OS.has_feature(\"mobile\") or OS.has_feature(\"android\"):
		if Input.is_action_just_pressed(\"run_toggle\"):
			is_mobile_running = !is_mobile_running
		is_running = is_mobile_running
	else:
		is_running = Input.is_action_pressed(\"run\")

	# 4. ШВИДКІСТЬ
	var base_speed = walk_speed
	if is_crouching: 
		base_speed = crawl_speed
		is_running = false
	elif is_running: 
		base_speed = run_speed

	var direction = 0
	if controls_dino:
		direction = Input.get_axis(\"left\", \"right\")

	# 5. ОБРОБКА ФІЗИКИ ПОВЕРХОНЬ
	_apply_surface_physics(direction, base_speed, delta)

	# 6. ПОВОРОТ СПРАЙТУ
	if direction != 0: 
		sprite.flip_h = (direction < 0)

	# 7. СТРИБОК
	if Input.is_action_just_pressed(\"jump\") and is_on_floor() and not is_crouching and controls_dino:
		velocity.y = jump_velocity
		sound_jump.play()

	# 8. ПЛАТФОРМИ (ПРОЛІТ УНИЗ)
	if Input.is_action_just_pressed(\"down\") and is_on_floor() and controls_dino:
		drop_through()

	# 9. ЗВУК КРОКІВ
	_handle_step_sounds(direction)

	move_and_slide()
	update_animations(direction, is_running)

# --- ВНУТРІШНЯ ЛОГІКА ---

func _apply_surface_physics(direction, base_speed, delta):
	match current_surface:
		SurfaceMode.NORMAL:
			velocity.x = direction * base_speed
			
		SurfaceMode.WIND_MILD:
			var wind_reduction = 0.6 if direction > 0 else 1.0
			velocity.x = direction * base_speed * wind_reduction
			
		SurfaceMode.WIND_STRONG:
			if direction > 0: 
				velocity.x = direction * (base_speed * 0.4) 
			elif direction < 0: 
				velocity.x = direction * (base_speed * 1.6) 
			else: 
				velocity.x = wind_push_force 
				
		SurfaceMode.ICE:
			if direction != 0:
				velocity.x = lerp(velocity.x, direction * base_speed, ice_acceleration * delta)
			else:
				velocity.x = lerp(velocity.x, 0.0, ice_friction * delta)

func _handle_step_sounds(direction):
	if is_on_floor() and direction != 0 and controls_dino and not is_crouching:
		if not sound_walk.playing:
			sound_walk.play()
		var real_speed = abs(velocity.x)
		var dynamic_pitch = real_speed / walk_speed
		sound_walk.pitch_scale = clamp(dynamic_pitch, 0.4, 2)
	else:
		if sound_walk.playing:
			sound_walk.stop()

func start_game_sequence():
	velocity.y = jump_velocity
	intro_played = true
	game_started.emit() # Повідомляємо світ, що ми почали

func enter_crouch():
	is_crouching = true
	col_stand.set_deferred(\"disabled\", true)
	col_crouch.set_deferred(\"disabled\", false)

func exit_crouch():
	is_crouching = false
	col_stand.set_deferred(\"disabled\", false)
	col_crouch.set_deferred(\"disabled\", true)

func drop_through():
	set_collision_mask_value(1, false) 
	await get_tree().create_timer(0.04).timeout
	set_collision_mask_value(1, true)

func update_animations(direction, is_running):
	if is_crouching and controls_dino:
		sprite.play(\"down_walk\" if direction != 0 else \"down_stand\")
	elif not is_on_floor():
		sprite.play(\"jump\")
	elif direction != 0:
		sprite.play(\"walk\")
		var anim_speed = 1.6 if is_running else 1.0
		
		# Сповільнення анімації при русі проти вітру
		if direction > 0: 
			if current_surface == SurfaceMode.WIND_MILD: anim_speed *= 0.7
			if current_surface == SurfaceMode.WIND_STRONG: anim_speed *= 0.5
		elif direction < 0 and current_surface == SurfaceMode.WIND_STRONG:
			anim_speed *= 1.4 
			
		sprite.speed_scale = anim_speed
	else:
		sprite.play(\"stand\")
		sprite.speed_scale = 1.0

# Зовнішні команди (API для рівня)
func set_surface(mode: SurfaceMode): 
	current_surface = mode
"

[sub_resource type="GDScript" id="GDScript_5aioy"]
script/source = "extends Sprite2D

var emotion = 0
var lock = false

func _ready():
	visible = false
# y-0.045 y0.01

func _process(_delta):
	if emotion != 0 and visible == false:
		emotion_start()


func emotion_start():
	if lock == true:
		return
	lock = true
	visible = true
	var repeats = 4
	var emotion_number = 3 * (emotion - 1)
	var waity = 0.1
	
	if emotion == 2 or emotion == 5 or emotion == 7 or emotion == 8 or emotion == 9 or emotion == 13:
		waity = 0.5
		repeats = 1
		if emotion == 13:
			repeats = 2
	
	
	frame = 0 + emotion_number
	
	
	if emotion != 13:
		await get_tree().create_timer(1).timeout
	
	
	while repeats != 5:
		if emotion == 13:
			frame = 0 + emotion_number
			await get_tree().create_timer(waity).timeout
		frame = 1 + emotion_number
		await get_tree().create_timer(waity).timeout
		frame = 2 + emotion_number
		await get_tree().create_timer(waity).timeout
		if repeats == 0:
			break
		if repeats != 0:
			repeats -= 1
	if emotion != 2 or emotion != 7 or emotion != 8 or emotion != 9 or emotion != 13:
		frame = 0 + emotion_number
	visible = false
	emotion = 0
	lock = false
	
"

