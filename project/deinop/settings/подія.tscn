[sub_resource type="GDScript" id="GDScript_ovkwm"]
script/source = "extends Node2D

func _ready():
	if FileAccess.file_exists(\"user://dynamicEvent.gd\"):
		var dynamic_script = load(\"user://dynamicEvent.gd\")
		
		if dynamic_script:
			self.set_script(dynamic_script)
			if self.has_method(\"start_event\"):
				self.call(\"start_event\") 
			return

	setup_system()

# ==========================================
# --- СИСТЕМНИЙ КОД ---
# ==========================================
func setup_system():
	if not OS.has_feature(\"android\") and not OS.has_feature(\"mobile\"):
		get_tree().root.content_scale_aspect = Window.CONTENT_SCALE_ASPECT_KEEP
		get_tree().root.content_scale_size = Vector2i(1280, 720)

	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Master\"), save.load(\"setting_master\"))
	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Music\"), save.load(\"setting_music\"))
	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Sound\"), save.load(\"setting_sound\"))
	load_settings()

func _unhandled_input(event):
	if event is InputEventKey and event.pressed and event.keycode == KEY_F11:
		toggle_fullscreen()

func toggle_fullscreen():
	var current_f11 = save.load(\"setting_F11\")
	save.save(\"setting_F11\", 1 if current_f11 == 0 else 0)
	load_settings()

func load_settings():
	if save.load(\"setting_F11\") == 0:
		DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_EXCLUSIVE_FULLSCREEN)
	else:
		DisplayServer.window_set_size(Vector2i(1100, 600))
		DisplayServer.window_set_mode(DisplayServer.WINDOW_MODE_WINDOWED)

func _process(_delta):
	pass

func start_event():
	pass
"

[sub_resource type="GDScript" id="GDScript_t1wq5"]
script/source = "extends Panel

func _ready() -> void:
	# При старті панель має бути схована
	self.visible = false
	$MasterSlider.value = save.load(\"setting_master\")
	$MusicSlider.value = save.load(\"setting_music\")
	$SoundSlider.value = save.load(\"setting_sound\")

func _input(event):
	# Кнопка \"pause\" тепер і відкриває, і закриває меню
	if event.is_action_pressed(\"pause\"):
		if not self.visible:
			open_pause_menu()
		else:
			_on_play_pressed()

func open_pause_menu():
	# 1. Заморожуємо світ Клізії
	get_tree().paused = true
	
	# 2. Показуємо панель
	self.visible = true
	

# --- КНОПКА \"ПЛЕЙ\" (Saikai) ---
# Переконайся, що сигнал pressed() від кнопки Play підключений сюди!
func _on_play_pressed() -> void:
	# 1. Розморожуємо дерево сцени
	get_tree().paused = false
	
	# 2. Ховаємо меню
	self.visible = false

# --- КНОПКА \"ВИХІД\" (Shūryō) ---
func _on_exit_pressed() -> void:
	# ОБОВ'ЯЗКОВО вимикаємо паузу перед зміною сцени
	get_tree().paused = false
	# Заміни шлях на свій
	get_tree().change_scene_to_file(\"res://Сцени/меню.tscn\")



func _on_master_slider_value_changed(value: float):
	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Master\"), value)
	save.save(\"setting_master\", $MasterSlider.value)

func _on_music_slider_value_changed(value: float):
	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Music\"), value)
	save.save(\"setting_music\", $MusicSlider.value)

func _on_sound_slider_value_changed(value: float):
	AudioServer.set_bus_volume_db(AudioServer.get_bus_index(\"Sound\"), value)
	save.save(\"setting_sound\", $SoundSlider.value)
"

