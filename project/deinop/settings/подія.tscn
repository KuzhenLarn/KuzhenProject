script/source = "extends Button


func _ready():
	if save.load(\"Broshura\") == 1:
		visible = true
	else:
		visible = false


func _process(_delta):
	pass


func _on_pressed() -> void:
	var console = $\"../..\"
	var broshura = $\"../../../../List/Broshura/1V\"
	var dino = $\"../../../../../Dino\"
	var consoleS = $\"../../../../../Dino/Console\"
	# 1. Ховаємо консоль
	console.close_console()
	
	# 2. Відкриваємо брошуру
	broshura.show_title()
	
	# 3. Чекаємо на сигнал закриття від брошури
	await broshura.brochure_closed
	
	# 4. РОЗБЛОКОВУЄМО ДІНО ТА ЗНІМАЄМО ЗАТЕМНЕННЯ!
	if is_instance_valid(dino):
		dino.controls_dino = true
		consoleS.visible = false
		dino._apply_tint(Color(\"ffffff\"))
"

